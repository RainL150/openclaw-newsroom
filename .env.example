# Required for LLM curation
GEMINI_API_KEY=your-gemini-api-key

# Optional fallbacks / enrichers
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
GH_TOKEN=
TAVILY_API_KEY=
TWITTERAPI_IO_KEY=

# LLM editor tuning
MIN_SCORE_THRESHOLD=60
SECTION_MAX_ITEMS=40
LLM_BATCH_SIZE=30

# Storage and rendering
NEWSROOM_OUTPUT_DIR=./outputs
NEWSROOM_MEMORY_DIR=./memory
NEWSROOM_TZ=Asia/Shanghai
NEWSROOM_HTML_ENABLED=1
NEWSROOM_FILE_PREVIEW_LINES=30
