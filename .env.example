# Required for LLM curation
GEMINI_API_KEY=your-gemini-api-key

# Optional fallbacks / enrichers
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
GH_TOKEN=
TAVILY_API_KEY=
TWITTERAPI_IO_KEY=

# 策编/分析由谁执行：llm_api（默认，本机直接调 llm_editor API）| agent
# 详见 references/analysis_execution.zh.md 与 SKILL.md
NEWSROOM_ANALYSIS_EXECUTOR=llm_api

# agent 模式下声明使用哪种 agent CLI（仅作语义标签，供 SKILL.md / Hook 内分支）：
# openclaw | claude_code | codex | cursor | aider | hermes | ...
# NEWSROOM_AGENT_KIND=codex

# agent 模式下的可执行 Hook（接收与 llm_editor 相同的 "$@"），须将 JSON 行写到 stdout
# NEWSROOM_AGENT_HOOK=/path/to/agent_analysis_hook.sh
# 或内联 shell（慎用；须自行保证 stdout 格式与 llm_editor 一致）
# NEWSROOM_AGENT_CMD='python3 "$NEWSROOM_SCRIPT_DIR/llm_editor.py" --file "$NEWSROOM_ENRICHED_FILE"'

# 旧名兼容（dispatcher 自动映射，无需迁移即可继续工作；新配置推荐使用上面的 agent/KIND/HOOK）：
#   NEWSROOM_ANALYSIS_EXECUTOR=openclaw_agent + NEWSROOM_OPENCLAW_ANALYSIS_HOOK/_CMD
#   NEWSROOM_ANALYSIS_EXECUTOR=claude_code   + NEWSROOM_CLAUDE_CODE_ANALYSIS_HOOK/_CMD

# LLM editor tuning
MIN_SCORE_THRESHOLD=60
SECTION_MAX_ITEMS=40
LLM_BATCH_SIZE=30

# Storage and rendering
NEWSROOM_OUTPUT_DIR=./outputs
NEWSROOM_MEMORY_DIR=./memory
NEWSROOM_TZ=Asia/Shanghai
NEWSROOM_HTML_ENABLED=1
NEWSROOM_FILE_PREVIEW_LINES=30
